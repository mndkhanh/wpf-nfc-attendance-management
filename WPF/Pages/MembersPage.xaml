<UserControl x:Class="WPF.Pages.MembersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WPF.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StudentPhotoThumbnailConverter x:Key="StudentPhotoThumbnailConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleStyle}"
                           Text="Danh sách thành viên" />
                <TextBlock x:Name="MemberCountTextBlock"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           Text="0 thành viên hiện có trong câu lạc bộ" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <TextBox x:Name="SearchTextBox"
                         Margin="0,0,12,0"
                         Style="{StaticResource MemberToolbarSearchTextBoxStyle}"
                         ToolTip="Tìm kiếm SDT, MSSV, tên, NFC UID..."
                         TextChanged="SearchTextBox_TextChanged" />
                <Border Margin="0,0,12,0"
                        Padding="4"
                        Background="#F7F2EF"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RefreshButton"
                                Style="{StaticResource ToolbarActionButtonStyle}"
                                Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Text="&#xE72C;" />
                                <TextBlock Text="Làm mới" />
                            </StackPanel>
                        </Button>
                        <Border Width="1"
                                Margin="2,4"
                                Background="{StaticResource BorderBrush}" />
                        <Button x:Name="EditMemberButton"
                                Style="{StaticResource ToolbarActionButtonStyle}"
                                Click="EditMemberButton_Click"
                                Foreground="{StaticResource AccentBrush}"
                                IsEnabled="False">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Text="&#xE70F;" />
                                <TextBlock Text="Sửa" />
                            </StackPanel>
                        </Button>
                        <Border Width="1"
                                Margin="2,4"
                                Background="{StaticResource BorderBrush}" />
                        <Button x:Name="DeleteMemberButton"
                                Style="{StaticResource ToolbarActionButtonStyle}"
                                Click="DeleteMemberButton_Click"
                                Foreground="{StaticResource DangerBrush}"
                                IsEnabled="False">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Text="&#xE74D;" />
                                <TextBlock Text="Xóa" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Button Height="40"
                        Padding="18,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddMemberButton_Click"
                        Content="+ Đăng ký thành viên" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Thông tin thành viên" />
                    <TextBlock x:Name="SelectionStatusTextBlock"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Chọn 1 thành viên để sửa hoặc xóa" />
                </DockPanel>

                <DataGrid x:Name="MembersGrid"
                          Grid.Row="1"
                          Margin="0,10,0,0"
                          Style="{StaticResource AppDataGridStyle}"
                          IsReadOnly="True"
                          RowHeight="72"
                          SelectionMode="Single"
                          SelectionChanged="MembersGrid_SelectionChanged"
                          MouseDoubleClick="MembersGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="92"
                                                Header="Ảnh">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Border Width="52"
                                                Height="52"
                                                Background="#F4ECE7"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Viewbox Margin="14"
                                                     Stretch="Uniform">
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="&#xE77B;" />
                                            </Viewbox>
                                        </Border>
                                        <Border Width="52"
                                                Height="52"
                                                CornerRadius="14"
                                                ClipToBounds="True">
                                            <Image Source="{Binding PhotoPath, Converter={StaticResource StudentPhotoThumbnailConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Width="130"
                                            Header="MSSV"
                                            Binding="{Binding StudentCode}" />
                        <DataGridTextColumn Width="220"
                                            Header="Họ và tên"
                                            Binding="{Binding FullName}" />
                        <DataGridTextColumn Width="220"
                                            Header="NFC UID"
                                            Binding="{Binding NfcUid}" />
                        <DataGridTextColumn Width="150"
                                            Header="Số điện thoại"
                                            Binding="{Binding Phone}" />
                        <DataGridTextColumn Width="140"
                                            Header="Trạng thái"
                                            Binding="{Binding Status}" />
                        <DataGridTextColumn Width="120"
                                            Header="Ngày tham gia"
                                            Binding="{Binding JoinedDate}" />
                        <DataGridTextColumn Width="220"
                                            Header="Email"
                                            Binding="{Binding Email}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
