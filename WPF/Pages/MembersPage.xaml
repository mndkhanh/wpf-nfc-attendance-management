<UserControl x:Class="WPF.Pages.MembersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleStyle}"
                           Text="Danh sách thành viên" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           Text="34 thành viên hiện có trong câu lạc bộ" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <TextBox Width="240"
                         Margin="0,0,12,0"
                         Style="{StaticResource InputTextBoxStyle}"
                         Foreground="{StaticResource MutedBrush}"
                         Text="Tìm kiếm SDT, MSSV..." />
                <Button Style="{StaticResource AccentButtonStyle}"
                        Click="AddMemberButton_Click"
                        Content="+ Đăng ký thành viên" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Thông tin thành viên" />
                    <TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Template UI cho luồng thành viên" />
                </DockPanel>

                <DataGrid x:Name="MembersGrid"
                          Grid.Row="1"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="130" Header="MSSV" Binding="{Binding StudentCode}" />
                        <DataGridTextColumn Width="220" Header="Họ và tên" Binding="{Binding FullName}" />
                        <DataGridTextColumn Width="220" Header="NFC UID" Binding="{Binding NfcUid}" />
                        <DataGridTextColumn Width="150" Header="Số điện thoại" Binding="{Binding Phone}" />
                        <DataGridTextColumn Width="140" Header="Trạng thái" Binding="{Binding Status}" />
                        <DataGridTextColumn Width="120" Header="Ngày tham gia" Binding="{Binding JoinedDate}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
