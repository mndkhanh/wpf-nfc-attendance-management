<UserControl x:Class="WPF.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"
                       Text="Dashboard tổng quan" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       Text="Trang mẫu để tổng hợp nhanh các chỉ số quan trọng" />
        </StackPanel>

        <ItemsControl x:Name="MetricItemsControl"
                      Grid.Row="2">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,12,0"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedBrush}"
                                       Text="{Binding Title}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Text="{Binding Value}" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="{Binding Subtitle}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Buổi tập sắp tới" />

                    <DataGrid x:Name="DashboardSessionsGrid"
                              Grid.Row="1"
                              Style="{StaticResource AppDataGridStyle}"
                             IsReadOnly="True" >
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="220" Header="Buổi tập" Binding="{Binding SessionName}" />
                            <DataGridTextColumn Width="240" Header="Chủ đề" Binding="{Binding Topic}" />
                            <DataGridTextColumn Width="160" Header="Thời gian" Binding="{Binding StartTime}" />
                            <DataGridTextColumn Width="120" Header="Trạng thái" Binding="{Binding Status}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Nhắc việc nhanh" />
                        <TextBlock Margin="0,16,0,0"
                                   Text="• Tạo buổi điểm danh mới cho thứ 5" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="• Cập nhật thẻ NFC cho 2 thành viên mới" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="• Đối soát quỹ cuối tuần" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Thông báo" />
                        <TextBlock Margin="0,16,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
