<UserControl x:Class="WPF.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"
                       Text="Cài đặt" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       Text="Trang mẫu cho cấu hình hệ thống, thông báo và NFC" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Thông tin chung câu lạc bộ" />
                    <TextBlock Margin="0,16,0,0"
                               Style="{StaticResource LabelTextStyle}"
                               Text="Tên câu lạc bộ" />
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="CLB Võ Kudo" />
                    <TextBlock Style="{StaticResource LabelTextStyle}"
                               Text="Mô tả ngắn" />
                    <TextBox Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="Môi trường tập luyện, điểm danh và quản lý tài chính cho một CLB duy nhất." />
                    <Button Width="140"
                            Height="30"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Lưu thay đổi" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Thông báo" />
                        <CheckBox Margin="0,16,0,10"
                                  Content="Bật thông báo khi có sinh viên quét NFC" />
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="True"
                                  Content="Hiển thị nhắc lịch buổi tập" />
                        <CheckBox Content="Nhắc thu phí thành viên cuối tháng" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Đồng bộ dữ liệu" />
                        <TextBlock Margin="0,16,0,0"
                                   Style="{StaticResource LabelTextStyle}"
                                   Text="Đồng bộ USB" />
                        <TextBlock Margin="0,16,0,0"
                                   Style="{StaticResource LabelTextStyle}"
                                   Text="Đồng bộ qua file" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
