<UserControl x:Class="WPF.Pages.FinancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="FinanceActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="74" />
        </Style>

        <Style x:Key="FinanceListGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource AppDataGridStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#C1C1C1" />
            <Setter Property="BorderBrush" Value="#A7A7A7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FFFDFB" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="RowHeight" Value="42" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--<StackPanel>
                <TextBlock Style="{StaticResource PageTitleStyle}"
                           Text="Các khoản thu/ chi tài chính" />
                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold">
                    <Run Text="Tổng số dư: " />
                    <Run x:Name="TotalBalanceRun"
                         Foreground="{StaticResource SuccessBrush}"
                         Text="+ 8.200.000" />
                </TextBlock>
            </StackPanel>-->
            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                <TextBlock FontWeight="SemiBold" Text="Tổng số dư: " />
                <TextBlock x:Name="TotalBalanceRun"
               FontWeight="SemiBold"
               Foreground="{StaticResource SuccessBrush}"
               Text="" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Height="30"
                        VerticalAlignment="Top">
                <Button Style="{StaticResource FinanceActionButtonStyle}"
                        Click="AddIncomeButton_Click"
                        Content="+ Thu" />
                <Button Style="{StaticResource FinanceActionButtonStyle}"
                        Click="AddExpenseButton_Click"
                        Content="- Chi" />
                <Button Margin="0"
                        Style="{StaticResource FinanceActionButtonStyle}"
                        Click="AddMemberFeeButton_Click"
                        Width="150"
                        Content="+ Thu phí thành viên" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#B8B8B8"
                BorderBrush="#A7A7A7"
                BorderThickness="1"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl x:Name="RecentTransactionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="20,18"
                                    Background="White">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#2E2E2E"
                                               Text="{Binding Description}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Margin="18,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{Binding AmountBrush}"
                                               Text="{Binding AmountDisplay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Row="2">
                    <TextBlock FontWeight="Bold"
                               Foreground="#3A3535"
                               Text="Danh sách các tài khoản mục tài chính" />
                </StackPanel>

                <DataGrid x:Name="FinanceGrid"
                          Grid.Row="4"
                          Style="{StaticResource FinanceListGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="110"
                                            Header="Ngày"
                                            Binding="{Binding TransactionDate}" />
                        <DataGridTextColumn Width="150"
                                            Header="Danh mục"
                                            Binding="{Binding Category}" />
                        <DataGridTextColumn Width="*"
                                            Header="Nội dung"
                                            Binding="{Binding Description}" />
                        <DataGridTemplateColumn Width="130"
                                                Header="Số tiền">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="{Binding AmountBrush}"
                                               Text="{Binding AmountDisplay}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
