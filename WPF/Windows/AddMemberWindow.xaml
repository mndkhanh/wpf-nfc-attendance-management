<Window x:Class="WPF.Windows.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký thành viên"
        Width="760"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#E7E0DB">
    <Border Margin="24"
            Background="White"
            CornerRadius="20"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource SectionTitleStyle}"
                       Text="Đăng ký thành viên" />

            <Grid Grid.Row="1"
                  Margin="0,20,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="140"
                        Height="180"
                        Background="{StaticResource LightMutedBrush}"
                        CornerRadius="16" />

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="Tên" />
                    <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="Nhập họ và tên" />

                    <TextBlock Grid.Row="1" Style="{StaticResource LabelTextStyle}" Text="NFC" />
                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="Hãy tap thẻ NFC" />

                    <TextBlock Grid.Row="2" Style="{StaticResource LabelTextStyle}" Text="MSSV" />
                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="Nhập MSSV" />

                    <TextBlock Grid.Row="3" Style="{StaticResource LabelTextStyle}" Text="Ảnh" />
                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="Link ảnh" />

                    <TextBlock Grid.Row="4" Style="{StaticResource LabelTextStyle}" Text="Số điện thoại" />
                    <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="Nhập số điện thoại" />

                    <TextBlock Grid.Row="5" Style="{StaticResource LabelTextStyle}" Text="Ghi chú" />
                    <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="Thông tin bổ sung" />
                </Grid>
            </Grid>

            <Button Grid.Row="2"
                    Width="120"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Xác nhận" />
        </Grid>
    </Border>
</Window>
