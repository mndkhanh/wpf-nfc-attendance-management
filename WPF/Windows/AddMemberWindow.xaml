<Window x:Class="WPF.Windows.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký thành viên"
        Width="780"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#E7E0DB">
    <Border Margin="0,0,0,0"
            Background="White"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="WindowHeaderTextBlock"
                       Style="{StaticResource SectionTitleStyle}"
                       Text="Đăng ký thành viên mới" />

            <Grid Grid.Row="1"
                  Margin="0,20,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="FinanceColumnDef" Width="0" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Width="160"
                            Height="210"
                            Background="{StaticResource LightMutedBrush}"
                            CornerRadius="16"
                            ClipToBounds="True">
                        <Grid>
                            <!-- Normal Photo View -->
                            <Grid x:Name="NormalPhotoGrid">
                                <Image x:Name="StudentPhotoImage"
                                       Stretch="UniformToFill" />
                                <StackPanel x:Name="PhotoPlaceholderPanel"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="48"
                                               Text="&#xE77B;" />
                                    <TextBlock Margin="0,10,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="Chưa có ảnh" />
                                </StackPanel>
                            </Grid>

                            <!-- Live Camera View -->
                            <Grid x:Name="CameraPreviewGrid" Visibility="Collapsed">
                                <Image x:Name="CameraPreviewImage" Stretch="UniformToFill" />
                                <Border VerticalAlignment="Bottom" Background="#80000000" Padding="4">
                                    <Button x:Name="CaptureButton"
                                            Height="30"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="CaptureButton_Click"
                                            Content="CHỤP" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Button x:Name="SelectPhotoButton"
                            Margin="0,14,0,8"
                            Height="30"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="SelectPhotoButton_Click"
                            Content="Chọn file ảnh" />
                    <Button x:Name="CameraModeButton"
                            Margin="0,0,0,8"
                            Height="30"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CameraModeButton_Click"
                            Content="Chụp từ Camera" />
                    <Button x:Name="RemovePhotoButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="30"
                            Click="RemovePhotoButton_Click"
                            Content="Xóa ảnh"
                            IsEnabled="False" />
                    <Button x:Name="CancelCameraButton"
                            Margin="0,8,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelCameraButton_Click"
                            Content="Hủy Camera"
                            Visibility="Collapsed"
                            Foreground="{StaticResource DangerBrush}" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="Họ và tên" />
                    <TextBox x:Name="FullNameTextBox" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="1" Style="{StaticResource LabelTextStyle}" Text="Mã số sinh viên (MSSV)" />
                    <TextBox x:Name="StudentCodeTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="2" Style="{StaticResource LabelTextStyle}" Text="Mã thẻ NFC (UID)" />
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NfcUidTextBox" 
                                 Style="{StaticResource InputTextBoxStyle}"
                                 IsReadOnly="True"
                                 Background="#F0F1F3" />
                        <Button x:Name="ScanNfcButton"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Width="40"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ScanNfcButton_Click"
                                ToolTip="Bấm để bắt đầu quét NFC">
                            <TextBlock FontFamily="Segoe MDL2 Assets" 
                                       FontSize="16" 
                                       Text="&#xE946;" />
                        </Button>
                        <Button x:Name="EraseNfcButton"
                                Grid.Column="2"
                                Margin="4,0,0,0"
                                Width="40"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="EraseNfcButton_Click"
                                Foreground="{StaticResource DangerBrush}"
                                ToolTip="Xóa mã NFC UID">
                            <TextBlock FontFamily="Segoe MDL2 Assets" 
                                       FontSize="14" 
                                       Text="&#xE74D;" />
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="3" Style="{StaticResource LabelTextStyle}" Text="Số điện thoại" />
                    <TextBox x:Name="PhoneTextBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="4" Style="{StaticResource LabelTextStyle}" Text="Email" />
                    <TextBox x:Name="EmailTextBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="5" Style="{StaticResource LabelTextStyle}" Text="Trạng thái" />
                    <ComboBox x:Name="StatusComboBox"
                              Grid.Row="5"
                              Grid.Column="1"
                              Style="{StaticResource InputComboBoxStyle}"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Active" />
                        <ComboBoxItem Content="Inactive" />
                    </ComboBox>

                    <StackPanel Grid.Row="5"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,57,0,-57">
                        <Button Width="110"
                                Margin="0,0,12,0"
                                Height="30"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Hủy"
                                IsCancel="True" />
                        <Button x:Name="ConfirmButton"
                                Width="120"
                                Height="30"
                                Style="{StaticResource AccentButtonStyle}"
                                Content="Xác nhận"
                                Click="ConfirmButton_Click" />
                    </StackPanel>
                </Grid>

                <!-- Financial History Panel (edit mode only) -->
                <Border x:Name="FinanceHistoryPanel"
                        Grid.Column="3"
                        Margin="20,0,0,0"
                        Padding="16"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Lịch sử tài chính" />

                        <!-- Unpaid section -->
                        <TextBlock Grid.Row="2"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{StaticResource DangerBrush}"
                                   Text="Chưa thanh toán" />
                        <DataGrid x:Name="UnpaidTransactionsGrid"
                                  Grid.Row="3"
                                  Style="{StaticResource AppDataGridStyle}"
                                  IsReadOnly="True"
                                  Margin="0,4,0,0"
                                  RowHeight="34"
                                  ColumnHeaderHeight="32"
                                  MinHeight="80">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="100" Header="Ngày" Binding="{Binding TransactionDate, StringFormat=\{0:dd/MM/yyyy\}}" />
                                <DataGridTextColumn Width="*" Header="Nội dung" Binding="{Binding Description}" />
                                <DataGridTextColumn Width="100" Header="Số tiền" Binding="{Binding Amount, StringFormat=\{0:N0\}}" />
                                <DataGridTemplateColumn Width="70" Header="">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✓ Thu"
                                                    FontSize="11"
                                                    Padding="6,2"
                                                    Cursor="Hand"
                                                    Foreground="{StaticResource SuccessBrush}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="MarkAsPaidButton_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Paid section -->
                        <TextBlock Grid.Row="5"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Text="Đã thanh toán" />
                        <DataGrid x:Name="PaidTransactionsGrid"
                                  Grid.Row="6"
                                  Style="{StaticResource AppDataGridStyle}"
                                  IsReadOnly="True"
                                  Margin="0,4,0,0"
                                  RowHeight="34"
                                  ColumnHeaderHeight="32"
                                  MinHeight="80">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="100" Header="Ngày" Binding="{Binding TransactionDate, StringFormat=\{0:dd/MM/yyyy\}}" />
                                <DataGridTextColumn Width="*" Header="Nội dung" Binding="{Binding Description}" />
                                <DataGridTextColumn Width="100" Header="Số tiền" Binding="{Binding Amount, StringFormat=\{0:N0\}}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>


        </Grid>
    </Border>
</Window>
