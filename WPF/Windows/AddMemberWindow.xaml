<Window x:Class="WPF.Windows.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký thành viên"
        Width="780"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#E7E0DB">
    <Border Margin="24"
            Background="White"
            CornerRadius="20"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="WindowHeaderTextBlock"
                       Style="{StaticResource SectionTitleStyle}"
                       Text="Đăng ký thành viên mới" />

            <Grid Grid.Row="1"
                  Margin="0,20,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Width="160"
                            Height="210"
                            Background="{StaticResource LightMutedBrush}"
                            CornerRadius="16"
                            ClipToBounds="True">
                        <Grid>
                            <Image x:Name="StudentPhotoImage"
                                   Stretch="UniformToFill" />
                            <StackPanel x:Name="PhotoPlaceholderPanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="48"
                                           Text="&#xE77B;" />
                                <TextBlock Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="Chưa có ảnh" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Button x:Name="SelectPhotoButton"
                            Margin="0,14,0,10"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="SelectPhotoButton_Click"
                            Content="Chọn ảnh" />
                    <Button x:Name="RemovePhotoButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="RemovePhotoButton_Click"
                            Content="Xóa ảnh"
                            IsEnabled="False" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="Họ và tên" />
                    <TextBox x:Name="FullNameTextBox" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="1" Style="{StaticResource LabelTextStyle}" Text="Mã số sinh viên (MSSV)" />
                    <TextBox x:Name="StudentCodeTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="2" Style="{StaticResource LabelTextStyle}" Text="Mã thẻ NFC (UID)" />
                    <TextBox x:Name="NfcUidTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="3" Style="{StaticResource LabelTextStyle}" Text="Số điện thoại" />
                    <TextBox x:Name="PhoneTextBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="4" Style="{StaticResource LabelTextStyle}" Text="Email" />
                    <TextBox x:Name="EmailTextBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Grid.Row="5" Style="{StaticResource LabelTextStyle}" Text="Trạng thái" />
                    <ComboBox x:Name="StatusComboBox"
                              Grid.Row="5"
                              Grid.Column="1"
                              Style="{StaticResource InputComboBoxStyle}"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Active" />
                        <ComboBoxItem Content="Inactive" />
                    </ComboBox>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Hủy"
                        IsCancel="True" />
                <Button x:Name="ConfirmButton"
                        Width="120"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Xác nhận"
                        Click="ConfirmButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
