<Window x:Class="WPF.Windows.MemberFeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thu phí thành viên"
        Width="460"
        Height="620"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PopupFieldBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9D9D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="48" />
        </Style>

        <Style x:Key="PopupTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="16,0,16,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PopupComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="10,0,12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PopupActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Width" Value="84" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Border Style="{StaticResource PopupFieldBorderStyle}" />
            <TextBox x:Name="FeeNameTextBox"
                     Style="{StaticResource PopupTextBoxStyle}" />
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#272727"
                       IsHitTestVisible="False"
                       Text="Tên khoản phí thu thành viên">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=FeeNameTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource PopupFieldBorderStyle}" />
            <TextBox x:Name="FeeAmountTextBox"
                     Style="{StaticResource PopupTextBoxStyle}" />
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#272727"
                       IsHitTestVisible="False"
                       Text="Số tiền">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=FeeAmountTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Student Search -->
        <TextBlock Grid.Row="4"
                   Style="{StaticResource LabelTextStyle}"
                   Margin="0,0,0,4"
                   Text="Chọn danh sách sinh viên" />
        <Grid Grid.Row="4" Margin="0,22,0,0">
            <Border Style="{StaticResource PopupFieldBorderStyle}" Height="40" />
            <TextBox x:Name="SearchTextBox"
                      Style="{StaticResource PopupTextBoxStyle}"
                      TextChanged="SearchTextBox_TextChanged" />
            <TextBlock Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       FontStyle="Italic"
                       Foreground="#888"
                       IsHitTestVisible="False"
                       Text="Tìm kiếm sinh viên...">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Student List (Multi-select) -->
        <Border Grid.Row="6"
                Background="White"
                BorderBrush="#D9D9D9"
                BorderThickness="1"
                CornerRadius="8">
            <ListBox x:Name="StudentListBox"
                     BorderThickness="0"
                     SelectionMode="Extended">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Margin="4,2"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Content="{Binding DisplayName}"
                                  VerticalContentAlignment="Center"
                                  FontSize="13" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Button Grid.Row="8"
                Click="ConfirmButton_Click"
                HorizontalAlignment="Right"
                Width="100"
                Height="30"
                Style="{StaticResource PopupActionButtonStyle}"
                Content="Xác nhận" />
    </Grid>
</Window>