<Window x:Class="WPF.Windows.MemberFeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thu phí thành viên"
        Width="560"
        Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#D8D1CC">
    <Border Margin="24"
            Background="White"
            CornerRadius="18"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource SectionTitleStyle}"
                       Text="Tạo khoản thu phí thành viên" />

            <TextBlock Grid.Row="1"
                       Margin="0,18,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Tên khoản phí" />
            <TextBox Grid.Row="1"
                     Margin="0,30,0,0"
                     Style="{StaticResource InputTextBoxStyle}"
                     Text="Phí sinh hoạt tháng 3" />

            <TextBlock Grid.Row="2"
                       Margin="0,12,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Số tiền" />
            <TextBox Grid.Row="2"
                     Margin="0,24,0,0"
                     Style="{StaticResource InputTextBoxStyle}"
                     Text="200000" />

            <TextBlock Grid.Row="3"
                       Margin="0,12,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Chọn sinh viên" />
            <ComboBox Grid.Row="3"
                      Margin="0,24,0,0"
                      Style="{StaticResource InputComboBoxStyle}"
                      SelectedIndex="0">
                <ComboBoxItem Content="Nguyễn Văn An - SE150111" />
                <ComboBoxItem Content="Trần Thị Bích - SE150222" />
                <ComboBoxItem Content="Lê Hoàng Cường - SE150333" />
            </ComboBox>

            <Button Grid.Row="4"
                    Width="120"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Xác nhận" />
        </Grid>
    </Border>
</Window>
