<Window x:Class="WPF.Windows.FinanceEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo khoản tài chính"
        Width="520"
        Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#D8D1CC">
    <Border Margin="24"
            Background="White"
            CornerRadius="18"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="DialogTitleText"
                       Style="{StaticResource SectionTitleStyle}"
                       Text="Tạo khoản thu" />

            <TextBlock Grid.Row="1"
                       Margin="0,20,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Tên khoản thu / chi" />
            <TextBox Grid.Row="1"
                     Margin="0,30,0,0"
                     Style="{StaticResource InputTextBoxStyle}"
                     Text="Nhập tên khoản mục" />

            <TextBlock Grid.Row="2"
                       Margin="0,12,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Số tiền" />
            <TextBox Grid.Row="2"
                     Margin="0,24,0,0"
                     Style="{StaticResource InputTextBoxStyle}"
                     Text="Nhập số tiền" />

            <Button Grid.Row="3"
                    Width="120"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Xác nhận" />
        </Grid>
    </Border>
</Window>
