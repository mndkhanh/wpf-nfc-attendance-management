<Window x:Class="WPF.Windows.FinanceEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo khoản tài chính"
        Width="360"
        Height="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF">
    <Window.Resources>
        <Style x:Key="PopupFieldBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9D9D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="48" />
        </Style>

        <Style x:Key="PopupTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="16,0,16,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PopupActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Width" Value="84" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Border Style="{StaticResource PopupFieldBorderStyle}" />
            <TextBox x:Name="EntryNameTextBox"
                     Style="{StaticResource PopupTextBoxStyle}" />
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#272727"
                       IsHitTestVisible="False"
                       Text="Tên khoản thu/ chi">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=EntryNameTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource PopupFieldBorderStyle}" />
            <TextBox x:Name="AmountTextBox"
                     Style="{StaticResource PopupTextBoxStyle}" />
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#272727"
                       IsHitTestVisible="False"
                       Text="Số tiền">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=AmountTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Button Grid.Row="4"
                Click="ConfirmButton_Click"
                HorizontalAlignment="Right"
                Style="{StaticResource PopupActionButtonStyle}"
                Width="100"
                Height="30"
                Content="Xác nhận" />
    </Grid>
</Window>
