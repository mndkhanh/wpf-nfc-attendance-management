<Window x:Class="WPF.Windows.AttendanceExecutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bắt đầu điểm danh"
        WindowState="Maximized"
        Background="#F5F5F7" 
        Width="1200" Height="800"
        MinWidth="1000" MinHeight="700">
    <Grid Margin="32" Background="#F5F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SessionTitleText"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#201C1C"
                       Text="Buổi điểm danh: tập luyện buổi chiều" />

            <Button Grid.Column="1"
                    Padding="24,12"
                    Background="#8B1D1D"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="FinishSessionButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" 
                                           Text="&#xEF3B;" 
                                           Margin="0,0,10,0" 
                                           VerticalAlignment="Center"/>
                                <ContentPresenter />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                Kết thúc buổi điểm danh
            </Button>
        </Grid>

        <!-- Main Body Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*" />
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Attendance DataGrid -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="18"
                    BorderBrush="#E6DEDA"
                    BorderThickness="1"
                    Padding="8">
                <DataGrid x:Name="LiveAttendanceGrid"
                          Style="{DynamicResource AppDataGridStyle}"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="120" Header="MSSV" Binding="{Binding StudentCode}" />
                        <DataGridTextColumn Width="240" Header="Họ và tên" Binding="{Binding FullName}" />
                        <DataGridTextColumn Width="120" Header="Giờ vào" Binding="{Binding CheckInTime, StringFormat=\{0:HH:mm:ss\}}" />
                        <DataGridTextColumn Width="*" Header="Ghi chú" Binding="{Binding Note}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Right: Info Panel -->
            <StackPanel Grid.Column="2">
                <!-- Student Info Section -->
                <Border Background="White"
                        CornerRadius="18"
                        BorderBrush="#E6DEDA"
                        BorderThickness="1"
                        Padding="24"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#352F2F"
                                   Text="Thông tin sinh viên" />
                        
                        <Border Width="140"
                                Height="140"
                                Margin="0,24,0,16"
                                Background="#F1ECE8"
                                CornerRadius="18">
                            <TextBlock HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="64" 
                                       Text="&#xE77B;" 
                                       Foreground="#6E6764"/>
                        </Border>
                        
                        <TextBlock x:Name="StudentNameText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Text="Nguyễn Văn An"
                                   HorizontalAlignment="Center" />
                        
                        <TextBlock x:Name="StudentCodeText"
                                   Margin="0,4,0,0"
                                   FontSize="16"
                                   Foreground="#6E6764"
                                   Text="SE150111"
                                   HorizontalAlignment="Center" />
                        
                        <TextBlock x:Name="NfcUidText"
                                   Margin="0,16,0,0"
                                   FontSize="14"
                                   Foreground="#6E6764"
                                   Text="UID: 04:4B:2A:82:C7:5E:80"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Finance / Stats Section -->
                <Border Background="#C0C0C0"
                        CornerRadius="18"
                        Padding="24"
                        MinHeight="180">
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Text="Thêm 1 section cho tài chính"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- DEBUG: Firebase status bar -->
        <Border Grid.Row="3" Margin="0,16,0,0" Background="#1E1E1E" CornerRadius="8" Padding="12,8">
            <TextBlock x:Name="NfcStatusText"
                       Text="⏳ Khởi động..."
                       Foreground="#A8FF78"
                       FontFamily="Consolas"
                       FontSize="13" />
        </Border>
    </Grid>
</Window>
