<Window x:Class="WPF.Windows.FinanceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh sửa giao dịch"
        Width="450"
        Height="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF">
    <Window.Resources>
        <Style x:Key="PopupFieldBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9D9D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="48" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="PopupTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="16,0,16,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PopupComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="10,0,12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="PopupActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style x:Key="DeleteButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <!-- Row 1: Type + Date -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <!-- Row 2: Category -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <!-- Row 3: Description -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <!-- Row 4: Amount + PaymentMethod -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <!-- Row 5: PaymentStatus -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <!-- Row 6: Student (read-only) -->
            <RowDefinition Height="Auto" />
            <!-- Spacer -->
            <RowDefinition Height="*" />
            <!-- Buttons -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Window Title -->
        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#201C1C"
                   Text="Chỉnh sửa giao dịch" />

        <!-- Row 1: Type + Date side by side -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="LOẠI" />
                <Border Style="{StaticResource PopupFieldBorderStyle}">
                    <ComboBox x:Name="TypeComboBox"
                              Style="{StaticResource PopupComboBoxStyle}">
                        <ComboBoxItem Content="Thu" />
                        <ComboBoxItem Content="Chi" />
                    </ComboBox>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="NGÀY GIAO DỊCH" />
                <Border Style="{StaticResource PopupFieldBorderStyle}">
                    <DatePicker x:Name="TransactionDatePicker"
                                BorderThickness="0"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                Margin="8,0" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Row 2: Category -->
        <StackPanel Grid.Row="4">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="DANH MỤC" />
            <Border Style="{StaticResource PopupFieldBorderStyle}">
                <TextBox x:Name="CategoryTextBox"
                         Style="{StaticResource PopupTextBoxStyle}" />
            </Border>
        </StackPanel>

        <!-- Row 3: Description -->
        <StackPanel Grid.Row="6">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="NỘI DUNG / MÔ TẢ" />
            <Border Style="{StaticResource PopupFieldBorderStyle}">
                <TextBox x:Name="DescriptionTextBox"
                         Style="{StaticResource PopupTextBoxStyle}" />
            </Border>
        </StackPanel>

        <!-- Row 4: Amount + PaymentMethod -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="SỐ TIỀN (VND)" />
                <Border Style="{StaticResource PopupFieldBorderStyle}">
                    <TextBox x:Name="AmountTextBox"
                             Style="{StaticResource PopupTextBoxStyle}" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PHƯƠNG THỨC" />
                <Border Style="{StaticResource PopupFieldBorderStyle}">
                    <ComboBox x:Name="PaymentMethodComboBox"
                              Style="{StaticResource PopupComboBoxStyle}">
                        <ComboBoxItem Content="Tiền mặt" />
                        <ComboBoxItem Content="Chuyển khoản" />
                        <ComboBoxItem Content="Khác" />
                    </ComboBox>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Row 5: Payment Status -->
        <StackPanel x:Name="PaymentStatusPanel"
                    Grid.Row="10">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TRẠNG THÁI THANH TOÁN" />
            <Border Style="{StaticResource PopupFieldBorderStyle}">
                <ComboBox x:Name="PaymentStatusComboBox"
                          Style="{StaticResource PopupComboBoxStyle}">
                    <ComboBoxItem Content="Paid" IsSelected="True" />
                    <ComboBoxItem Content="Unpaid" />
                </ComboBox>
            </Border>
        </StackPanel>

        <!-- Row 6: Student (read-only info, only shown when linked) -->
        <StackPanel x:Name="StudentInfoPanel"
                    Grid.Row="12"
                    Margin="0,0,0,0"
                    Visibility="Collapsed">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="SINH VIÊN LIÊN KẾT" />
            <Border Style="{StaticResource PopupFieldBorderStyle}"
                    Background="#F7F2EF">
                <TextBlock x:Name="StudentInfoText"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#444" />
            </Border>
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="80"
                    Style="{StaticResource DeleteButtonStyle}"
                    Click="DeleteButton_Click"
                    Content="Xóa" />

            <Button Grid.Column="2"
                    Width="80"
                    Style="{StaticResource PopupActionButtonStyle}"
                    Background="White"
                    Foreground="{StaticResource AccentBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Click="CancelButton_Click"
                    Content="Huỷ" />

            <Button Grid.Column="4"
                    Width="100"
                    Style="{StaticResource PopupActionButtonStyle}"
                    Click="SaveButton_Click"
                    Content="Lưu thay đổi" />
        </Grid>
    </Grid>
</Window>
