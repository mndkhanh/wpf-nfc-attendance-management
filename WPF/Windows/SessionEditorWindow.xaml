<Window x:Class="WPF.Windows.SessionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bắt đầu buổi điểm danh"
        Width="520"
        Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#D8D1CC">
    <Border Margin="24"
            Background="White"
            CornerRadius="18"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource SectionTitleStyle}"
                       Text="Tạo buổi điểm danh" />

            <TextBlock Grid.Row="1"
                       Margin="0,20,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Tên buổi điểm danh" />
            <TextBox Grid.Row="1"
                     Margin="0,30,0,0"
                     Style="{StaticResource InputTextBoxStyle}"
                     Text="Tên buổi điểm danh" />

            <TextBlock Grid.Row="2"
                       Margin="0,12,0,6"
                       Style="{StaticResource LabelTextStyle}"
                       Text="Chi tiết" />
            <TextBox Grid.Row="2"
                     Margin="0,24,0,0"
                     Height="90"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Style="{StaticResource InputTextBoxStyle}"
                     Text="Chi tiết: description ... blabla" />

            <Button Grid.Row="3"
                    Width="120"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Xác nhận" />
        </Grid>
    </Border>
</Window>
