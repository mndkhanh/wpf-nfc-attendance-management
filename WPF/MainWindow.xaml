<Window x:Class="WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CLB Võ Kudo"
        Width="1440"
        Height="900"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- White Header Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,0">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource IconButtonStyle}"
                        Content="&#xE700;" 
                        VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBox x:Name="HeaderSearchBox"
                             Style="{StaticResource HeaderSearchTextBoxStyle}"
                             Margin="20,0" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE7ED;" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                CornerRadius="0,40,0,0">
            <Grid Margin="0,40,0,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Branding -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <TextBlock Text="CLB VÕ KUDO"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" />
                    <Border Height="1"
                            Width="160"
                            Margin="0,20,0,0"
                            Background="#44FFFFFF" />
                </StackPanel>

                <!-- Navigation List -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="AttendanceNavButton"
                            Style="{StaticResource SidebarNavButtonStyle}"
                            Click="AttendanceNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Text="&#xE823;" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Điểm danh" />
                        </Grid>
                    </Button>

                    <Button x:Name="MembersNavButton"
                            Style="{StaticResource SidebarNavButtonStyle}"
                            Click="MembersNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Text="&#xE77B;" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Thành viên" />
                        </Grid>
                    </Button>

                    <Button x:Name="FinanceNavButton"
                            Style="{StaticResource SidebarNavButtonStyle}"
                            Click="FinanceNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Text="&#xEAFD;" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Tài chính" />
                        </Grid>
                    </Button>

                    <Button x:Name="DashboardNavButton"
                            Style="{StaticResource SidebarNavButtonStyle}"
                            Click="DashboardNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Text="&#xF246;" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Dashboard" />
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Bottom Button -->
                <Button x:Name="SettingsNavButton"
                        Grid.Row="2"
                        Style="{StaticResource SidebarNavButtonStyle}"
                        Click="SettingsNavButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE713;" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Cài đặt" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Host -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White"
                Padding="32">
            <ContentControl x:Name="MainContentHost" />
        </Border>
    </Grid>
</Window>
